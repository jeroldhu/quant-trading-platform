# Quant Trading 环境变量
# 复制为 .env 并填入实际值

# --- 数据目录 ---
QUANT_DATA_ROOT=./data
QUANT_SNAPSHOT_ROOT=./snapshots

# --- 市场数据模式 ---
# snapshot: 从快照拉取（研究端默认）
# live: 直接从网络源采集（需谨慎使用，会触发大量请求）
QUANT_MARKET_MODE=snapshot

# --- 远程存储 ---
# PostgreSQL 连接串（可选，周频信号持久化需要）
# QUANT_POSTGRES_DSN=postgresql://USER:PASSWORD@127.0.0.1:5432/quant_trading

# SSH 别名，用于拉取阿里云快照
QUANT_REMOTE_SSH_HOST=aliyun

# 远程快照根目录（供 rsync 拉取）
QUANT_REMOTE_SNAPSHOT_ROOT=/srv/quant-trading/snapshots

# --- 数据源 ---
# Tushare API Token（主题股票数据启用后使用；密钥只放 .env）
# QUANT_TUSHARE_TOKEN=your_token_here

# --- 数据管道 ---
# 请求超时（秒）
QUANT_REQUEST_TIMEOUT_SECONDS=20

# 每秒请求数
QUANT_REQUESTS_PER_SECOND=1.0

# 最低剩余磁盘空间（GB），低于此值采集停止
QUANT_MIN_FREE_GB=10

# --- AI 评估 (DeepSeek) ---
# 仅当 configs/reporting.yaml 中 ai.enabled=true 时需要；其余参数在该 YAML 配置。
# DEEPSEEK_API_KEY=<your-key>

# --- 日志 ---
QUANT_LOG_LEVEL=INFO
