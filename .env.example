# Quant Trading 环境变量
# 复制为 .env 并填入实际值

# --- 数据目录 ---
QUANT_DATA_ROOT=./data
QUANT_SNAPSHOT_ROOT=./snapshots

# --- 市场数据模式 ---
# snapshot: 从快照拉取（研究端默认）
# live: 直接从网络源采集（需谨慎使用，会触发大量请求）
QUANT_MARKET_MODE=snapshot

# --- 远程存储 ---
# PostgreSQL 连接串（可选，周频信号持久化需要）
# QUANT_DATABASE_URL=postgresql://user:pass@127.0.0.1:15432/quant

# SSH 别名，用于拉取阿里云快照
QUANT_REMOTE_SSH_HOST=aliyun

# 远程 PostgreSQL 根目录
QUANT_REMOTE_POSTGRES_ROOT=/opt/quant-theme/postgresql

# --- 数据源 ---
# Tushare API Token（可选，用于股票基础信息和复权因子）
# TUSHARE_TOKEN=your_token_here

# 雪球 Cookie（可选，用于实时行情）
# XUEQIU_TOKEN=your_token_here

# 启用/禁用腾讯数据源
QUANT_TENCENT_ENABLED=true

# 东方财富历史接口地址（默认不需要修改）
# QUANT_EASTMONEY_HISTORY_URL=https://push2his.eastmoney.com/api/qt/stock/kline/get

# --- 数据管道 ---
# 请求超时（秒）
QUANT_REQUEST_TIMEOUT=20

# 每秒请求数
QUANT_REQUESTS_PER_SECOND=1.0

# 发布最低覆盖率
QUANT_MIN_PUBLISH_COVERAGE=0.99

# 最低剩余磁盘空间（GB），低于此值采集停止
QUANT_MIN_FREE_GB=10

# --- AI 评估 (DeepSeek) ---
# DeepSeek API Key（必填，否则 AI 评估不可用）
DEEPSEEK_API_KEY=sk-your-key-here
# DeepSeek API 地址（默认不需要改）
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# 模型选择
# DEEPSEEK_MODEL=deepseek-chat
# 思考深度：low / medium / high / xhigh
# DEEPSEEK_REASONING_EFFORT=medium
# 是否启用 AI 评估
# QUANT_AI_ENABLED=true

# --- 日志 ---
QUANT_LOG_LEVEL=INFO
